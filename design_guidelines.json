  },
  "overall_composition": {
    "grid": "Bento grid inspired, asymmetrical, max-w-6xl mx-auto px-6",
    "philosophy": "Negative space is a feature. Do not cram elements. Use 8rem margins between major sections. Text blocks should be narrow (max-w-prose) for comfortable reading.",
    "testing_attributes": "All interactive elements (nav links, buttons, project cards, theme toggles, command palette items) MUST include a kebab-cased `data-testid` attribute reflecting their role."
  }
}